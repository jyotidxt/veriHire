# PostgreSQL database URL connection string used by Prisma
DATABASE_URL="your_postgresql_database_connection_url"

# Clerk Authentication Publishable and Secret Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"

# OpenAI API Key used for job analysis
OPENAI_API_KEY="your_openai_api_key"

# Stripe Subscription billing keys
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
